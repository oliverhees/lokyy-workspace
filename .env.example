# ============================================================
# Lokyy Workspace — Environment (copy to .env, fill in values)
# Build in Public: NEVER put real secrets in versioned files.
# ============================================================

# ─── App ───────────────────────────────────────────────────
APP_ENV=development
APP_BIND=127.0.0.1
# Host port for the backend (container is always 8000 internally).
APP_PORT=8008
# Host port for PostgreSQL. The prod DB (docker-compose.yml) is internal-only.
# For local dev start the DB via the override, which maps it to this host port:
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d db
DB_PORT=5435

# ─── Database (PostgreSQL + pgvector) ──────────────────────
# Used by docker-compose to provision the db container:
POSTGRES_USER=lokyy
POSTGRES_PASSWORD=lokyy
POSTGRES_DB=lokyy
# Connection string used by a HOST backend (dev): matches DB_PORT above.
# In-container the backend uses @db:5432 (set in docker-compose.yml).
DATABASE_URL=postgresql+psycopg://lokyy:lokyy@localhost:5435/lokyy

# ─── Auth & Security ───────────────────────────────────────
AUTH_ENABLED=true
SECRET_KEY=change_me_generate_a_random_value
SECURE_COOKIES=false

# ─── LLM Providers (model-agnostic; leave blank to disable) ─
# Local:
OLLAMA_BASE_URL=http://localhost:11434
# Cloud (optional — keep blank unless used):
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=

# ─── Embeddings ────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ─── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8008
